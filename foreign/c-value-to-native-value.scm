(cond-expand
  (kawa
    (define (value->native-value value type)
      (cond ((c-bytevector? value)
             (c-bytevector-pointer value))
            ((equal? (c-type-name type) 'i8)
             (java.lang.Integer value))
            ((equal? (c-type-name type) 'u8)
             (java.lang.Integer value))
            ((equal? (c-type-name type) 'short)
             (java.lang.Short value))
            ((equal? (c-type-name type) 'unsigned-short)
             (java.lang.Short value))
            ((equal? (c-type-name type) 'int)
             (java.lang.Integer value))
            ((equal? (c-type-name type) 'unsigned-int)
             (java.lang.Integer value))
            ((equal? (c-type-name type) 'long)
             (java.lang.Long value))
            ((equal? (c-type-name type) 'unsigned-long)
             (java.lang.Long value))
            ((equal? (c-type-name type) 'float)
             (java.lang.Float value))
            ((equal? (c-type-name type) 'double)
             (java.lang.Double value))
            ((equal? (c-type-name type) 'char)
             (java.lang.Char value))
            (else value))))
  (else
    (define (value->native-value value)
      (if (c-bytevector? value)
        (c-bytevector-pointer value)
        value))))
